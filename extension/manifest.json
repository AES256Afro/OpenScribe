{
  "manifest_version": 3,
  "name": "OpenScribe Companion",
  "version": "0.1.0",
  "description": "Send selected text or page audio to the OpenScribe desktop app.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:43110/*"],
  "action": { "default_title": "Send to OpenScribe", "default_popup": "popup.html" }
}
